# ============================================================
# Observatory Pipeline — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# API — Remote observatory-api (required)
# ------------------------------------------------------------
API_BASE_URL=https://your-cloud-host.com/api/v1
API_KEY=your-secret-api-key-here

# ------------------------------------------------------------
# FITS directory paths (inside the Docker container)
# These must match the volume mounts in docker-compose.yml
# ------------------------------------------------------------
FITS_INCOMING=/fits/incoming
FITS_ARCHIVE=/fits/archive
FITS_REJECTED=/fits/rejected

# ------------------------------------------------------------
# ASTAP plate solver
# ------------------------------------------------------------
ASTAP_BINARY=/usr/local/bin/astap
ASTAP_CATALOGS=/astap/catalogs

# Optional field-of-view hint in degrees for faster plate solving.
# Set to 0 (default) for auto-detection from FITS headers.
# Providing an approximate FOV speeds up plate solving significantly.
ASTAP_FOV_HINT=0

# ------------------------------------------------------------
# Quality control thresholds
# Tune these values for your telescope and local seeing.
# ------------------------------------------------------------

# Maximum acceptable median FWHM in arcseconds (focus quality)
QC_FWHM_MAX_ARCSEC=8.0

# Maximum acceptable PSF elongation ratio (tracking quality)
# 1.0 = perfectly round stars; >2.0 indicates trailing
QC_ELONGATION_MAX=2.0

# Minimum acceptable median SNR of detected sources
QC_SNR_MIN=5.0

# Minimum number of detected stars required to accept a frame
QC_STARS_MIN=10

# ------------------------------------------------------------
# Star detection filtering
# These parameters filter raw source detections to keep only
# point sources (stars) and reject extended objects (nebulae,
# galaxy parts) and artifacts (hot pixels, cosmic rays).
# ------------------------------------------------------------

# SEP source extraction thresholds
# Higher values = fewer detections (more conservative)
SEP_DETECT_THRESH=10.0
SEP_MIN_AREA=15

# FWHM range in arcseconds — sources outside this range are rejected
# Min: below this = hot pixel or cosmic ray (too sharp)
# Max: above this = extended object or badly defocused star
STAR_FWHM_MIN_ARCSEC=2.5
STAR_FWHM_MAX_ARCSEC=8.0

# Maximum elongation — above this is a trail or extended object
# Stars should be close to 1.0 (round)
STAR_ELONGATION_MAX=1.5

# Minimum SNR (peak/rms) — below this is likely noise
# Higher = fewer but more reliable detections
STAR_SNR_MIN=50.0

# ------------------------------------------------------------
# Catalog cross-matching
# ------------------------------------------------------------

# Cone search radius (arcsec) for point-source catalog matching
MATCH_CONE_ARCSEC=5.0

# Wider cone radius (arcsec) for moving-object detection
MOVING_CONE_ARCSEC=30.0

# Magnitude delta that triggers a variability alert
DELTA_MAG_ALERT=0.5

# ------------------------------------------------------------
# Observatory site coordinates
# Used for topocentric ephemeris queries to JPL Horizons.
# Latitude / longitude in decimal degrees; elevation in metres.
# ------------------------------------------------------------
SITE_LAT=0.0
SITE_LON=0.0
SITE_ELEV=0

# ------------------------------------------------------------
# Normalization settings
# ------------------------------------------------------------

# Enable/disable automatic normalization of FITS header values and filenames.
# When enabled (default), normalizes:
#   - Object names: "M 51" → "M51", "NGC 1234" → "NGC1234"
#   - Filter names: "Blue" → "B", "Luminance" → "L", "H-Alpha" → "Ha"
#   - Frame types: "Light Frame" → "Light", "Dark Frame" → "Dark"
#   - Filenames: renamed to standard format {Object}_{Type}_{Filter}_{Exp}_{DateTime}.fits
# This ensures consistency across different capture software.
NORMALIZE_ENABLED=true

