# ============================================================
# Observatory Pipeline — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# API — Remote observatory-api (required)
# ------------------------------------------------------------
API_BASE_URL=https://your-cloud-host.com/api/v1
API_KEY=your-secret-api-key-here

# ------------------------------------------------------------
# FITS directory paths (inside the Docker container)
# These must match the volume mounts in docker-compose.yml
# ------------------------------------------------------------
FITS_INCOMING=/fits/incoming
FITS_ARCHIVE=/fits/archive
FITS_REJECTED=/fits/rejected

# ------------------------------------------------------------
# ASTAP plate solver
# ------------------------------------------------------------
ASTAP_BINARY=/usr/local/bin/astap
ASTAP_CATALOGS=/astap/catalogs

# ------------------------------------------------------------
# Quality control thresholds
# Tune these values for your telescope and local seeing.
# ------------------------------------------------------------

# Maximum acceptable median FWHM in arcseconds (focus quality)
QC_FWHM_MAX_ARCSEC=8.0

# Maximum acceptable PSF elongation ratio (tracking quality)
# 1.0 = perfectly round stars; >2.0 indicates trailing
QC_ELONGATION_MAX=2.0

# Minimum acceptable median SNR of detected sources
QC_SNR_MIN=5.0

# Minimum number of detected stars required to accept a frame
QC_STARS_MIN=10

# ------------------------------------------------------------
# Catalog cross-matching
# ------------------------------------------------------------

# Cone search radius (arcsec) for point-source catalog matching
MATCH_CONE_ARCSEC=5.0

# Wider cone radius (arcsec) for moving-object detection
MOVING_CONE_ARCSEC=30.0

# Magnitude delta that triggers a variability alert
DELTA_MAG_ALERT=0.5
